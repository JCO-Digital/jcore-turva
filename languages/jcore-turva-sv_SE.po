#: build/security.js:1 src/security/components/GeneralTab.js:129
msgid ""
"Forces browsers to use HTTPS for future visits. Only enable on HTTPS sites."
msgstr ""
"Tvingar webbläsare att använda HTTPS för framtida besök. Aktivera endast på "
"HTTPS-webbplatser."

#: build/security.js:1 src/security/components/GeneralTab.js:141
msgid "Max Age (seconds)"
msgstr "Max ålder (sekunder)"

#: build/security.js:1 src/security/components/GeneralTab.js:145
msgid ""
"How long browsers should remember to use HTTPS. Default: 31536000 (1 year)."
msgstr ""
"Hur länge webbläsare ska komma ihåg att använda HTTPS. Standard: 31536000 (1 "
"år)."

#: build/security.js:1 src/security/components/GeneralTab.js:164
msgid "X-Content-Type-Options: nosniff"
msgstr "X-Content-Type-Options: nosniff"

#: build/security.js:1 src/security/components/GeneralTab.js:168
msgid "Prevents browsers from MIME-sniffing the declared content type."
msgstr "Förhindrar webbläsare från att MIME-sniffa den deklarerade innehållstypen."

#: build/security.js:1 src/security/components/GeneralTab.js:179
msgid "X-XSS-Protection"
msgstr "X-XSS-Protection"

#: build/security.js:1 src/security/components/GeneralTab.js:180
msgid ""
"Legacy XSS filter for older browsers. Not needed if a strong CSP is in place."
msgstr ""
"Gammalt XSS-filter för äldre webbläsare. Behövs inte om en stark CSP används."

#: build/security.js:1 src/security/components/GeneralTab.js:191
msgid "Referrer-Policy"
msgstr "Referrer-Policy"

#: build/security.js:1 src/security/components/GeneralTab.js:192
msgid "Controls how much referrer information is included with requests."
msgstr "Styr hur mycket referrer-information som skickas med anropen."

#: build/security.js:1 src/security/components/GeneralTab.js:204
